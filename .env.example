# Server (Render/Railway/local)
PORT=3001
HOST=0.0.0.0
# CORS: true | false | single origin | comma-separated origins
CLIENT_ORIGIN=true

# Client (Vite; set in Vercel/Netlify env at build time)
# Production: your deployed API origin, no trailing slash
# VITE_SERVER_URL=https://virtual-cosmos-api.onrender.com

# Server: extra hostnames allowed for https (or http localhost) avatar image URLs
# (Presets /avatars/preset-1.svg … preset-6.svg always work.)
# AVATAR_ALLOWED_HOSTS=cdn.example.com,images.myapp.com
